UAPIS_BASE_URL=https://uapis.cn/api/v1
UAPIS_TIMEOUT=5.0
UAPIS_RETRIES=2
UAPIS_BACKOFF=0.6

MEMORY_DB_PATH=backend/data/memory.db

# LLM is required
# Option A: in-process llama.cpp (GGUF)
LLM_PROVIDER=llama_cpp
LLM_MODEL_PATH=E:\\models\\qwen2.5-1.5b-instruct-q4_k_m.gguf
LLM_LORA_PATH=
LLM_CTX=2048
LLM_GPU_LAYERS=20
LLM_THREADS=8
LLM_BATCH=512
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=300
LLM_RESPONSE_FORMAT=json_object

# Option B: Ollama local server
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2:1b

# OpenAI (if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=
OPENAI_COMPAT_MODE=

# Ollama (if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=30

RAG_KB_PATH=backend/rag/knowledge_base.jsonl
RAG_TOP_K=3
